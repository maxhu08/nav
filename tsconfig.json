{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "~/*": ["./*"]
    },
    "strict": true,
    "noEmit": true,
    "noEmitOnError": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun", "node", "chrome"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "index.ts"],
  "exclude": ["dist", "node_modules", "output"]
}
